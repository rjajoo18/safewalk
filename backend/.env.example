# Mapbox access token (Directions API)
MAPBOX_ACCESS_TOKEN=

# Path to pre-baked segment scores (produced by prebake.py).
# Defaults to <repo>/outputs/scored_segments.parquet; set this only to override.
# SCORED_SEGMENTS_PATH=outputs/scored_segments.parquet

# Comma-separated allowed CORS origins (Vercel frontend)
CORS_ORIGINS=http://localhost:3000

# Supabase — R4 gap_reports realtime integration
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
